// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH & USERS ====================

enum Role {
  STUDENT
  OWNER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  emailVerified   DateTime?
  phone           String?   @unique
  password        String
  image           String?
  role            Role      @default(STUDENT)
  gender          Gender?
  aadharNo        String?
  isPremium          Boolean   @default(false)
  premiumExpiry      DateTime?
  premiumGrantType   String?   // 'paid' | 'free_launch' | 'manual'
  subscriptionPlan   String?   // 'monthly' | 'quarterly' | 'yearly'
  subscriptionStart  DateTime?
  razorpayPaymentId  String?
  razorpayOrderId    String?
  superCoins         Int       @default(0)

  // Owner Premium (separate from student premium)
  isOwnerPremium          Boolean   @default(false)
  ownerPremiumExpiry      DateTime?
  ownerPremiumGrantType   String?   // 'paid' | 'free_launch' | 'manual'
  ownerSubscriptionPlan   String?   // 'monthly' | 'quarterly' | 'yearly'
  ownerSubscriptionStart  DateTime?
  ownerRazorpayPaymentId  String?
  ownerRazorpayOrderId    String?

  // Commission (Owners only)
  commissionPercentage  Float?    // Owner-specific commission rate
  bankAccountName       String?   // Account holder name
  bankAccountNumber     String?   // Bank account number (encrypted)
  bankIfscCode          String?   // IFSC code
  bankAccountType       String?   // 'savings' | 'current'

  isBlocked       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  properties      Property[]       @relation("OwnerProperties")
  bookings        Booking[]        @relation("StudentBookings")
  reviews         Review[]
  complaints      Complaint[]      @relation("StudentComplaints")
  complaintsOwner Complaint[]      @relation("OwnerComplaints")
  notifications   Notification[]
  chatMessages    ChatMessage[]
  coupons         UserCoupon[]
  cart            CartItem[]
  wishlist        Wishlist[]
  announcements   Announcement[]
  paymentLogs     PaymentLog[]
  personalizedOffers PersonalizedOffer[]
  premiumGrants   PremiumGrant[]
  warnings        UserWarning[]
  suspensions     UserSuspension[]
  commissionLogs  CommissionChangeLog[]
  payoutsReceived OwnerPayout[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==================== PROPERTIES & SERVICES ====================

enum ServiceType {
  HOSTEL
  PG
  LIBRARY
  COACHING
  MESS
  LAUNDRY
  GYM
  COWORKING
}

enum PropertyStatus {
  DRAFT
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

model Property {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  description       String         @db.Text
  serviceType       ServiceType
  status            PropertyStatus @default(PENDING)

  // Location
  address           String
  city              String
  state             String
  pincode           String
  latitude          Float?
  longitude         Float?
  nearbyLandmark    String?
  distanceMarket    String?
  distanceInstitute String?

  // Pricing
  price             Float
  gstRate           Float          @default(18)

  // Features
  isAC              Boolean        @default(false)
  hasWifi           Boolean        @default(false)
  forGender         Gender?
  occupancy         Int?
  foodIncluded      Boolean        @default(false)
  laundryIncluded   Boolean        @default(false)
  foodRating        Float?
  hasMedical        Boolean        @default(false)
  nearbyMess        String?
  nearbyLaundry     String?
  customAmenities   String[]       @default([])

  // Capacity
  capacity          Int?           // Total capacity (rooms/seats)
  availableRooms    Int?           // Currently available
  closingTime       String?        // e.g. "10:00 PM"

  // Cancellation
  cancellationPolicy String?      @db.Text

  // Images
  images            PropertyImage[]

  // Bank Details
  bankName          String?
  accountNo         String?
  ifscCode          String?
  upiId             String?

  // Rules
  rules             String?        @db.Text

  // Owner
  ownerId           String
  owner             User           @relation("OwnerProperties", fields: [ownerId], references: [id])

  // Relations
  bookings          Booking[]
  reviews           Review[]
  complaints        Complaint[]
  announcements     Announcement[]
  cartItems         CartItem[]
  wishlistItems     Wishlist[]
  pricingPlans      PricingPlan[]

  // Ratings (cached)
  avgRating         Float          @default(0)
  totalReviews      Int            @default(0)
  totalViews        Int            @default(0)

  // Relations
  visits            PropertyVisit[]
  serviceStudents   ServiceStudent[]
  engagementEvents  EngagementEvent[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([serviceType])
  @@index([city])
  @@index([status])
  @@index([totalViews])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  publicId   String?
  isWideShot Boolean  @default(false)
  order      Int      @default(0)
  category   String?  // e.g. "room", "bathroom", "exterior", "view", "common_area", "kitchen"
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

// ==================== PRICING PLANS ====================

model PricingPlan {
  id          String   @id @default(cuid())
  propertyId  String
  label       String   // e.g. "Monthly", "Quarterly", "Yearly"
  durationDays Int     // e.g. 30, 90, 365
  price       Float    // Price for this plan (before GST)
  isActive    Boolean  @default(true)

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
  @@map("pricing_plans")
}

// ==================== BOOKINGS ====================

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

model Booking {
  id            String        @id @default(cuid())
  bookingNo     String        @unique @default(cuid())
  studentId     String
  propertyId    String
  status        BookingStatus @default(PENDING)
  checkIn       DateTime
  checkOut      DateTime
  totalDays     Int           @default(1)
  totalPrice    Float
  gstAmount     Float
  grandTotal    Float
  isPrebooking  Boolean       @default(false)
  lateFeeWaiver Int           @default(0)
  planLabel     String?       // Pricing plan label (e.g. "Monthly", "Quarterly")
  notes         String?       @db.Text

  // Commission & Payout
  commissionPercentage  Float?    // Rate at time of booking
  commissionAmount      Float?    // Platform commission
  ownerPayoutAmount     Float?    // Amount to owner
  payoutStatus          String    @default("pending") // pending | processed | failed

  // Razorpay payment details
  razorpayOrderId   String?
  razorpayPaymentId String?   @unique
  razorpaySignature String?
  paymentStatus     String    @default("pending") // pending | paid | refunded | failed

  student       User          @relation("StudentBookings", fields: [studentId], references: [id])
  property      Property      @relation(fields: [propertyId], references: [id])
  complaints    Complaint[]
  payout        OwnerPayout?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([studentId])
  @@index([propertyId])
  @@index([status])
  @@map("bookings")
}

// ==================== REVIEWS ====================

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?  @db.Text
  userId     String
  propertyId String

  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, propertyId])
  @@map("reviews")
}

// ==================== COMPLAINTS ====================

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Complaint {
  id          String          @id @default(cuid())
  subject     String
  description String          @db.Text
  status      ComplaintStatus @default(OPEN)
  studentId   String
  ownerId     String?
  propertyId  String?
  bookingId   String?

  student     User            @relation("StudentComplaints", fields: [studentId], references: [id])
  owner       User?           @relation("OwnerComplaints", fields: [ownerId], references: [id])
  property    Property?       @relation(fields: [propertyId], references: [id])
  booking     Booking?        @relation(fields: [bookingId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("complaints")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  userId    String
  link      String?
  type      String?  // new_booking | booking_confirmed | booking_cancelled | payment_received | announcement

  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

// ==================== ANNOUNCEMENTS ====================

model Announcement {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  ownerId    String
  propertyId String?

  owner      User     @relation(fields: [ownerId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])

  createdAt  DateTime @default(now())

  @@map("announcements")
}

// ==================== SUPERADMIN ANNOUNCEMENTS ====================

enum AnnouncementType {
  OFFER
  UPDATE
  WARNING
  PROMOTION
  COMMISSION
}

enum AnnouncementTargetType {
  ALL_USERS
  ALL_OWNERS
  SELECTED_USERS
  SELECTED_OWNERS
  ALL
}

model SuperAdminAnnouncement {
  id               String                  @id @default(cuid())
  title            String
  message          String                  @db.Text
  type             AnnouncementType
  targetType       AnnouncementTargetType
  targetIds        String[]                @default([])
  createdById      String
  expiresAt        DateTime?
  isActive         Boolean                 @default(true)
  deliveryChannels String[]                @default(["notification"])
  reachCount       Int                     @default(0)
  commissionValue  Float?                  // For COMMISSION type

  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  readReceipts     AnnouncementReadReceipt[]

  @@index([isActive])
  @@index([type])
  @@index([createdAt])
  @@map("superadmin_announcements")
}

model AnnouncementReadReceipt {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  isRead         Boolean  @default(false)
  isDismissed    Boolean  @default(false)
  readAt         DateTime?

  announcement   SuperAdminAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
  @@map("announcement_read_receipts")
}

// ==================== CHAT / AI ====================

model ChatMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  isAI      Boolean  @default(false)
  userId    String

  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("chat_messages")
}

// ==================== PAYMENT LOGS ====================

model PaymentLog {
  id                String   @id @default(cuid())
  userId            String
  razorpayOrderId   String
  razorpayPaymentId String
  amount            Int      // in paise
  plan              String   // 'monthly' | 'quarterly' | 'yearly'
  status            String   // 'success' | 'failed'
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("payment_logs")
}

// ==================== COUPONS & REWARDS ====================

model Coupon {
  id          String       @id @default(cuid())
  code        String       @unique
  title       String
  description String?
  discount    Float
  isPercent   Boolean      @default(true)
  maxUses     Int          @default(100)
  usedCount   Int          @default(0)
  expiresAt   DateTime
  isActive    Boolean      @default(true)

  users       UserCoupon[]

  createdAt   DateTime     @default(now())

  @@map("coupons")
}

model UserCoupon {
  id       String  @id @default(cuid())
  userId   String
  couponId String
  isUsed   Boolean @default(false)

  user     User    @relation(fields: [userId], references: [id])
  coupon   Coupon  @relation(fields: [couponId], references: [id])

  @@unique([userId, couponId])
  @@map("user_coupons")
}

// ==================== CART ====================

model CartItem {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  checkIn    DateTime
  checkOut   DateTime

  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@map("cart_items")
}

// ==================== WISHLIST ====================

model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  propertyId String

  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@map("wishlists")
}

// ==================== ENGAGEMENT EVENTS ====================

enum EngagementEventType {
  CLICK
  WISHLIST_ADD
  CART_ADD
}

model EngagementEvent {
  id          String              @id @default(cuid())
  propertyId  String
  eventType   EngagementEventType
  userId      String?             // null for guests
  guestToken  String?             // anonymous visitor token
  ipAddress   String?
  month       String              // "2025-01" for fast monthly aggregation

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@index([propertyId, eventType])
  @@index([propertyId, month])
  @@index([propertyId, eventType, month])
  @@map("engagement_events")
}

// ==================== PROPERTY VISITS ====================

model PropertyVisit {
  id          String   @id @default(cuid())
  propertyId  String
  userId      String?  // null for guests
  ipAddress   String?
  sessionToken String? // for deduplicating guest visits
  userAgent   String?

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@index([propertyId, createdAt])
  @@index([propertyId, userId])
  @@index([propertyId, ipAddress, sessionToken])
  @@map("property_visits")
}

// ==================== SERVICE STUDENTS (Owner-uploaded) ====================

model ServiceStudent {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  email       String?
  phone       String?
  userId      String?  // linked user account (if exists)
  isVerified  Boolean  @default(false) // true if matched to existing user
  status      String   @default("ACTIVE") // ACTIVE | INACTIVE | LEFT
  seatNumber  String?  // optional seat/room number

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([propertyId, email])
  @@unique([propertyId, phone])
  @@index([propertyId])
  @@index([userId])
  @@map("service_students")
}

// ==================== SUPER ADMIN ====================

model SuperAdmin {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  lastLogin     DateTime?

  auditLogs     AuditLog[]
  premiumGrants PremiumGrant[]
  userWarnings  UserWarning[]
  userSuspensions UserSuspension[]

  @@map("superadmins")
}

model AuditLog {
  id            String   @id @default(cuid())
  superadminId  String
  actionType    String   // e.g. "EDIT_USER", "GRANT_PREMIUM", "SUSPEND_USER", "DELETE_REVIEW", etc.
  targetType    String   // e.g. "USER", "SERVICE", "BOOKING", "REVIEW", "OFFER"
  targetId      String
  targetName    String?
  beforeValue   String?  @db.Text // JSON string
  afterValue    String?  @db.Text // JSON string
  reason        String?  @db.Text

  superadmin    SuperAdmin @relation(fields: [superadminId], references: [id])

  createdAt     DateTime @default(now())

  @@index([superadminId])
  @@index([actionType])
  @@index([targetType])
  @@index([createdAt])
  @@map("audit_logs")
}

model PersonalizedOffer {
  id                    String   @id @default(cuid())
  assignedToUserId      String
  title                 String
  description           String   @db.Text
  discountType          String   // "percentage" | "flat"
  discountValue         Float
  applicableServiceTypes String[] @default([])
  startDate             DateTime @default(now())
  expiryDate            DateTime
  isStackable           Boolean  @default(false)
  isActive              Boolean  @default(true)
  isUsed                Boolean  @default(false)
  createdAt             DateTime @default(now())
  revokedAt             DateTime?

  assignedTo            User     @relation(fields: [assignedToUserId], references: [id])

  @@index([assignedToUserId])
  @@index([isActive])
  @@map("personalized_offers")
}

model PremiumGrant {
  id          String    @id @default(cuid())
  userId      String
  grantedById String
  grantType   String    // "manual" | "paid"
  startDate   DateTime  @default(now())
  expiryDate  DateTime? // null = lifetime
  isActive    Boolean   @default(true)
  revokedAt   DateTime?

  user        User         @relation(fields: [userId], references: [id])
  grantedBy   SuperAdmin   @relation(fields: [grantedById], references: [id])

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isActive])
  @@map("premium_grants")
}

model UserWarning {
  id              String   @id @default(cuid())
  userId          String
  warningMessage  String   @db.Text
  issuedById      String
  isRead          Boolean  @default(false)
  isDismissed     Boolean  @default(false)

  user            User       @relation(fields: [userId], references: [id])
  issuedBy        SuperAdmin @relation(fields: [issuedById], references: [id])

  issuedAt        DateTime @default(now())

  @@index([userId])
  @@map("user_warnings")
}

model UserSuspension {
  id            String    @id @default(cuid())
  userId        String
  reason        String    @db.Text
  suspendedById String
  suspendedAt   DateTime  @default(now())
  expiresAt     DateTime? // null = permanent
  isActive      Boolean   @default(true)
  reinstatedAt  DateTime?

  user          User       @relation(fields: [userId], references: [id])
  suspendedBy   SuperAdmin @relation(fields: [suspendedById], references: [id])

  @@index([userId])
  @@index([isActive])
  @@map("user_suspensions")
}

model PlatformAnalytics {
  id              String   @id @default(cuid())
  date            DateTime @unique
  totalUsers      Int      @default(0)
  totalOwners     Int      @default(0)
  totalServices   Int      @default(0)
  totalBookings   Int      @default(0)
  totalRevenue    Float    @default(0)
  newSignups      Int      @default(0)
  activeUsers     Int      @default(0)

  @@index([date])
  @@map("platform_analytics")
}

// ==================== COMMISSION CHANGE LOG ====================

model CommissionChangeLog {
  id              String   @id @default(cuid())
  ownerId         String
  previousRate    Float
  newRate         Float
  changedBy       String   // superadmin ID
  reason          String?

  owner           User     @relation(fields: [ownerId], references: [id])

  createdAt       DateTime @default(now())

  @@index([ownerId])
  @@map("commission_change_logs")
}

// ==================== OWNER PAYOUTS ====================

model OwnerPayout {
  id                String   @id @default(cuid())
  bookingId         String   @unique
  ownerId           String
  bookingAmount     Float
  commissionAmount  Float
  payoutAmount      Float
  payoutStatus      String   @default("pending") // pending | processed | failed
  razorpayPayoutId  String?
  failureReason     String?
  processedAt       DateTime?

  booking           Booking  @relation(fields: [bookingId], references: [id])
  owner             User     @relation(fields: [ownerId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([ownerId])
  @@index([payoutStatus])
  @@index([createdAt])
  @@map("owner_payouts")
}

// ==================== PLATFORM CONFIG ====================

model PlatformConfig {
  id                       String   @id @default(cuid())
  key                      String   @unique
  value                    String
  description              String?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("platform_config")
}
